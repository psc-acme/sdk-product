{
    "name": "psc-acme/sdk-product",
    "description": "Package sdk-product for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\SdkProduct\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "brick/math": "^0.12",
        "laravel/framework": "^11.0",
        "psr/event-dispatcher": "^1.0",
        "symfony/serializer": "^7.0"
    },
    "require-dev": {
        "infection/infection": "^0.27"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}